@echo off
:: コマンドプロンプトの文字コードをUTF-8に変更（日本語の文字化け防止）
chcp 65001 > nul
setlocal

echo ========================================
echo 一括パイプライン処理を開始します
echo ========================================

:: ==========================================
:: 1. 環境変数の設定 (APIキー)
:: ==========================================
:: ★ ここに取得した Gemini API キーを貼り付けてください
set GEMINI_API_KEY=YOUR_API_KEY_HERE

if "%GEMINI_API_KEY%"=="YOUR_API_KEY_HERE" (
    echo [エラー] バッチファイルをテキストエディタで開き、GEMINI_API_KEY を設定してください。
    pause
    exit /b 1
)

:: ==========================================
:: 2. 実行ファイルの存在確認
:: ==========================================
if not exist "run_whisper.py" (
    echo [エラー] 'run_whisper.py' が見つかりません。同じフォルダに配置してください。
    pause
    exit /b 1
)
if not exist "run_gemini.py" (
    echo [エラー] 'run_gemini.py' が見つかりません。同じフォルダに配置してください。
    pause
    exit /b 1
)

:: ==========================================
:: 3. 文字起こしの実行
:: ==========================================
echo.
echo --- [Step 1] 文字起こし (run_whisper.py) を実行します ---
python run_whisper.py

:: エラーチェック: 直前のコマンドが失敗した場合はここで処理を止める
if %ERRORLEVEL% NEQ 0 (
    echo.
    echo [エラー] run_whisper.py の実行中にエラーが発生しました。処理を中断します。
    pause
    exit /b %ERRORLEVEL%
)

:: ==========================================
:: 4. 要約の実行
:: ==========================================
echo.
echo --- [Step 2] 要約 (run_gemini.py) を実行します ---
python run_gemini.py

:: エラーチェック
if %ERRORLEVEL% NEQ 0 (
    echo.
    echo [エラー] run_gemini.py の実行中にエラーが発生しました。
    pause
    exit /b %ERRORLEVEL%
)

:: ==========================================
:: 5. 完了処理
:: ==========================================
echo.
echo ========================================
echo すべての処理が正常に完了しました！
echo フォルダ内の output フォルダを確認してください。
echo ========================================
pause
